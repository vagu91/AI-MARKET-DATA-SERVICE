AI_MARKET_SERVICE_NAME=AI-MARKET-DATA-SERVICE
AI_MARKET_ENVIRONMENT=local
AI_MARKET_LOG_LEVEL=INFO
AI_MARKET_DATABASE_PATH=./data/market_data_service.sqlite
AI_MARKET_QQQ_RECONSTRUCTED_WEIGHT_TTL_HOURS=12
AI_MARKET_QQQ_WEIGHT_TOTAL_TOLERANCE_PCT=1.0
AI_MARKET_QQQ_WEIGHT_MIN_COVERAGE_PCT=95.0
AI_MARKET_QQQ_WEIGHT_MAX_CONSTITUENT_PCT=25.0
AI_MARKET_SEC_CLASS_SHARES_TTL_HOURS=24
AI_MARKET_SEC_REQUEST_TIMEOUT_SECONDS=15
AI_MARKET_SEC_USER_AGENT=AI-MARKET-DATA-SERVICE your-email@example.com
AI_MARKET_INVESTING_CALENDAR_LOOKAHEAD_DAYS=35
AI_MARKET_TIMEZONE=Europe/Rome

# Storage retention and disk guardrails.
AI_MARKET_DIAGNOSTICS_DIR=./data/diagnostics
AI_MARKET_BACKUPS_DIR=./data/backups
AI_MARKET_LOGS_DIR=./logs
AI_MARKET_TEMP_DIR=./data/temp
AI_MARKET_DIAGNOSTICS_RETENTION_DAYS=7
AI_MARKET_DIAGNOSTICS_MAX_TOTAL_MB=250
AI_MARKET_DIAGNOSTICS_MAX_RUNS=10
AI_MARKET_BACKUPS_RETENTION_DAYS=14
AI_MARKET_BACKUPS_MAX_TOTAL_MB=500
AI_MARKET_BACKUPS_MAX_FILES=5
AI_MARKET_LOG_MAX_FILE_MB=10
AI_MARKET_LOG_BACKUP_COUNT=5
AI_MARKET_TEMP_RETENTION_HOURS=24
AI_MARKET_DISK_WARNING_FREE_MB=1024
AI_MARKET_DISK_CRITICAL_FREE_MB=512
AI_MARKET_STORAGE_CLEANUP_INTERVAL_HOURS=24

# Single-DB maintenance retention.
AI_MARKET_PROVIDER_OBSERVATIONS_RETENTION_DAYS=30
AI_MARKET_ENRICHMENT_RUNS_RETENTION_DAYS=30
AI_MARKET_EXPIRED_CACHE_RETENTION_DAYS=7
AI_MARKET_MARKET_NEWS_RETENTION_DAYS=30
AI_MARKET_MARKET_FACTS_RETENTION_DAYS=30
AI_MARKET_ECONOMIC_EVENTS_HISTORY_RETENTION_DAYS=730
AI_MARKET_SNAPSHOT_HISTORY_RETENTION_DAYS=90
AI_MARKET_DB_VACUUM_MIN_SIZE_MB=250
AI_MARKET_DB_VACUUM_MIN_RECLAIMABLE_MB=50

# Per-block acquisition timeouts. A timeout degrades that block only.
AI_MARKET_TIMEOUT_MACRO_SECONDS=30
AI_MARKET_TIMEOUT_EVENTS_SECONDS=30
AI_MARKET_TIMEOUT_NEWS_SECONDS=12
AI_MARKET_TIMEOUT_OFFICIAL_NEWS_SECONDS=4
AI_MARKET_TIMEOUT_NASDAQ_SECONDS=45
AI_MARKET_TIMEOUT_EARNINGS_SECONDS=12
AI_MARKET_TIMEOUT_COT_SECONDS=8
AI_MARKET_TIMEOUT_SENTIMENT_SECONDS=8
AI_MARKET_TIMEOUT_CANONICAL_SECONDS=4
AI_MARKET_TIMEOUT_ARTICLE_FETCH_SECONDS=4
AI_MARKET_TIMEOUT_AI_RESEARCH_SECONDS=180

# Advanced risk context. All sources are public exchange/FRED datasets.
AI_MARKET_ENABLE_CBOE_RISK_INDICES=true
AI_MARKET_ENABLE_CBOE_VIX_FUTURES=true
AI_MARKET_ENABLE_CBOE_PUT_CALL=true
AI_MARKET_RISK_CONTEXT_TTL_MINUTES=30
AI_MARKET_RISK_CONTEXT_HISTORY_MIN_POINTS=60
AI_MARKET_RISK_CURVE_FLAT_TOLERANCE_PCT=0.25
AI_MARKET_RISK_ALIGNMENT_MAX_GAP_MINUTES=1440

# Official free API keys. Leave blank to skip live macro calls and use provider errors/cache.
# Both prefixed and unprefixed names are supported; prefer the prefixed names in deployments.
AI_MARKET_FRED_API_KEY=
AI_MARKET_BEA_API_KEY=
AI_MARKET_BLS_API_KEY=
AI_MARKET_ALPHA_VANTAGE_API_KEY=
AI_MARKET_FMP_API_KEY=
AI_MARKET_OPENAI_API_KEY=
# FRED_API_KEY=
# BEA_API_KEY=
# BLS_API_KEY=
# ALPHA_VANTAGE_API_KEY=
# FMP_API_KEY=
# OPENAI_API_KEY=

# Fallbacks are off by default.
AI_MARKET_ENABLE_SCRAPER_FALLBACKS=false
AI_MARKET_ENABLE_EVENT_ENRICHMENT_SCRAPERS=true
AI_MARKET_ENABLE_OPENAI_EVENT_ENRICHMENT=false
AI_MARKET_ENABLE_BROWSER_SCRAPING=false
AI_MARKET_BROWSER_SCRAPING_HEADLESS=true
AI_MARKET_BROWSER_SCRAPING_TIMEOUT_SECONDS=15
AI_MARKET_BROWSER_SCRAPING_MAX_PAGES=3
AI_MARKET_ENABLE_AGGRESSIVE_SCRAPING=false
AI_MARKET_ENRICH_ONLY_HIGH_IMPACT=true
AI_MARKET_ENRICHMENT_MAX_EVENTS=10
AI_MARKET_EVENT_ENRICHMENT_CACHE_TTL_HOURS=24
AI_MARKET_ENABLE_TARGETED_SEARCH_ENRICHMENT=true
AI_MARKET_TARGETED_SEARCH_MAX_EVENTS=10
AI_MARKET_TARGETED_SEARCH_TIMEOUT_SECONDS=10
AI_MARKET_TARGETED_SEARCH_RECENCY_DAYS=30
AI_MARKET_TARGETED_SEARCH_REQUIRE_SOURCE_URL=true
AI_MARKET_ENABLE_OPENAI_FALLBACK=false
AI_MARKET_ENABLE_SCHEDULER=false
AI_MARKET_OPENAI_EVENT_ENRICHMENT_MODEL=gpt-5-mini
AI_MARKET_OPENAI_EVENT_ENRICHMENT_MAX_EVENTS=5
AI_MARKET_MANUAL_EVENT_ENRICHMENT_PATH=./data/manual_event_enrichment.json

# Persistent market facts/news DB and freshness policy.
AI_MARKET_ALLOW_STALE_FACTS=false
AI_MARKET_DEFAULT_NEWS_TTL_HOURS=24
AI_MARKET_DEFAULT_FACT_TTL_HOURS=24
AI_MARKET_READINESS_REQUIRE_NEWS=false
AI_MARKET_READINESS_REQUIRE_RATES=false
AI_MARKET_READINESS_REQUIRE_POSITIONING=false
AI_MARKET_READINESS_REQUIRE_SENTIMENT=false
AI_MARKET_READINESS_REQUIRE_PREDICTION_MARKETS=false
AI_MARKET_NEWS_WEEKEND_LOOKBACK_HOURS=72
AI_MARKET_NEWS_MARKET_OPEN_LOOKBACK_HOURS=24
AI_MARKET_NEWS_HOLIDAY_LOOKBACK_HOURS=72
AI_MARKET_QQQ_HOLDINGS_TTL_HOURS=24
AI_MARKET_QQQ_HOLDINGS_STALE_TOLERANCE_HOURS=72
AI_MARKET_EARNINGS_TTL_HOURS=24
AI_MARKET_ENABLE_FMP_EARNINGS=true
AI_MARKET_ENABLE_XTB_CALENDAR=true
AI_MARKET_XTB_CALENDAR_TIMEOUT_SECONDS=10
AI_MARKET_XTB_CALENDAR_MIN_IMPACT=2
AI_MARKET_XTB_CALENDAR_LOOKAHEAD_DAYS=7
AI_MARKET_XTB_CALENDAR_TTL_MINUTES=30

# AI Researcher fallback. Disabled by default; Codex CLI mode uses local login, not API billing.
AI_MARKET_ENABLE_AI_RESEARCHER=false
AI_MARKET_AI_RESEARCHER_MODE=codex_cli
AI_MARKET_AI_RESEARCHER_MAX_EVENTS=5
AI_MARKET_AI_RESEARCH_MAX_MACRO_EVENTS=5
AI_MARKET_AI_RESEARCH_MAX_NEWS=10
AI_MARKET_AI_RESEARCH_MAX_EARNINGS_SYMBOLS=13
AI_MARKET_AI_RESEARCH_MAX_COT_REQUESTS=1
AI_MARKET_AI_RESEARCH_MAX_SENTIMENT_REQUESTS=1
AI_MARKET_AI_RESEARCH_MIN_CONFIDENCE=0.5
AI_MARKET_AI_RESEARCH_REQUIRE_EVIDENCE=true
AI_MARKET_AI_RESEARCHER_ONLY_HIGH_IMPACT=true
AI_MARKET_AI_RESEARCHER_REQUIRE_SOURCE_URL=true
AI_MARKET_SAVE_FAILED_RESEARCH=true
AI_MARKET_CODEX_CLI_COMMAND=codex
AI_MARKET_CODEX_WORKSPACE_DIR=./data/ai_research_workspace
AI_MARKET_CODEX_RESEARCH_TIMEOUT_SECONDS=300

# Persistent asynchronous AI jobs. The worker is independent from the general scheduler.
# Keep both AI switches false unless a verified research environment is intentionally enabled.
AI_MARKET_SOURCE_POLICY_PATH=./config/source_policy.json
AI_MARKET_AI_WORKER_ENABLED=false
AI_MARKET_AI_WORKER_POLL_SECONDS=1
AI_MARKET_AI_JOB_LEASE_SECONDS=60
AI_MARKET_AI_JOB_MAX_RUNTIME_SECONDS=600
AI_MARKET_AI_JOB_MAX_ATTEMPTS=3
AI_MARKET_AI_WORKER_SHUTDOWN_TIMEOUT_SECONDS=10
AI_MARKET_AI_RESEARCH_WEB_ACCESS_ENABLED=false
AI_MARKET_AI_JOB_WORKSPACE_ROOT=./data/ai_research_jobs
AI_MARKET_AI_RUN_WINDOW_NEWS_MINUTES=15
AI_MARKET_AI_RUN_WINDOW_MISSING_EVENT_MINUTES=60
AI_MARKET_AI_RUN_WINDOW_SPEECH_MINUTES=30
AI_MARKET_AI_RUN_WINDOW_EARNINGS_MINUTES=60
AI_MARKET_AI_RUN_WINDOW_GENERAL_MARKET_MINUTES=30
AI_MARKET_AI_RUN_WINDOW_ACTUAL_REFRESH_MINUTES=15
# Keep false until an explicitly authorized single live smoke reaches LIVE_VERIFIED.
# READY_TO_SMOKE is offline readiness only.
AI_MARKET_RESEARCH_SCHEDULER_ENABLED=false
AI_MARKET_RESEARCH_PREMARKET_ENABLED=true
AI_MARKET_RESEARCH_SESSION_ENABLED=true
AI_MARKET_RESEARCH_POSTMARKET_ENABLED=true
AI_MARKET_RESEARCH_EVENT_TRIGGERS_ENABLED=true
AI_MARKET_RESEARCH_NEWS_ENABLED=true
AI_MARKET_RESEARCH_PREMARKET_TIME=08:00
AI_MARKET_RESEARCH_POSTMARKET_TIME=17:00
AI_MARKET_RESEARCH_SESSION_INTERVAL_MINUTES=30
AI_MARKET_RESEARCH_MAX_CONCURRENT_JOBS=1
# MNQ's 10 required topics are grouped into at most 8 planned searches.
# Prompt, schemas, runtime enforcement, recovery and telemetry use this same limit.
AI_MARKET_RESEARCH_MAX_SEARCHES=8
AI_MARKET_RESEARCH_MAX_OPENED_SOURCES=12
# observe records threshold warnings without stopping useful progress.
# enforce turns deduplicated terminal-action overshoot into BUDGET_EXCEEDED.
AI_MARKET_RESEARCH_BUDGET_MODE=observe
AI_MARKET_RESEARCH_LOOP_REPEAT_ACTION_THRESHOLD=3
AI_MARKET_RESEARCH_LOOP_NO_PROGRESS_ACTION_THRESHOLD=12
AI_MARKET_RESEARCH_LOOP_CYCLE_WINDOW=4
AI_MARKET_RESEARCH_LOOP_CYCLE_REPETITIONS=3
# Independent emergency safety ceiling; not an economic budget.
AI_MARKET_RESEARCH_EMERGENCY_MAX_TOOL_ACTIONS=200
AI_MARKET_RESEARCH_CHECKPOINT_ON_DEADLINE=true
# Production default: one backend invocation; source fetch and verification are service-owned.
AI_MARKET_RESEARCH_SINGLE_INVOCATION_ENABLED=true
AI_MARKET_RESEARCH_GATEWAY_TIMEOUT_SECONDS=12
AI_MARKET_RESEARCH_GATEWAY_MAX_REDIRECTS=4
AI_MARKET_RESEARCH_GATEWAY_RESPECT_ROBOTS=true
AI_MARKET_RESEARCH_GATEWAY_MAX_CONTENT_BYTES=5000000
AI_MARKET_RESEARCH_GATEWAY_MAX_TEXT_CHARS=200000
AI_MARKET_RESEARCH_GATEWAY_MIN_TEXT_CHARS=80
AI_MARKET_RESEARCH_GATEWAY_MAX_SOURCES_PER_RUN=32
AI_MARKET_RESEARCH_EVIDENCE_MATCH_THRESHOLD=0.88
AI_MARKET_RESEARCH_EVIDENCE_MIN_TOKENS=5
AI_MARKET_RESEARCH_DAILY_BUDGET_RUNS=8
AI_MARKET_RESEARCH_MINIMUM_FRESHNESS_MINUTES=15
AI_MARKET_RELEASE_REFRESH_RETRY_SECONDS=30,120,300,900,1800,3600
AI_MARKET_MAX_RELEASE_REFRESH_ATTEMPTS=6
AI_MARKET_OFFICIAL_FEED_DELAY_HOURS=24
AI_MARKET_OFFICIAL_ACTUAL_RETRY_SECONDS=30,120,300,900,1800,3600,3600,3600,3600,3600,3600,3600
AI_MARKET_OFFICIAL_ACTUAL_MAX_ATTEMPTS=48
AI_MARKET_RESEARCH_PRE_EVENT_WINDOW_MINUTES=120
AI_MARKET_RESEARCH_DAILY_BUDGET_SEARCHES=64
AI_MARKET_RESEARCH_DAILY_BUDGET_OPENED_SOURCES=96

# OpenAI API mode for future production use. Leave blank to skip API calls.
AI_MARKET_OPENAI_RESEARCH_MODEL=
AI_MARKET_OPENAI_RESEARCH_TIMEOUT_SECONDS=60
AI_MARKET_OPENAI_RESEARCH_TEMPERATURE=0

# Optional RSS fallback URL overrides for /news/latest.
# AI_MARKET_GOOGLE_NEWS_RSS_URL=https://news.google.com/rss/search
# AI_MARKET_YAHOO_FINANCE_RSS_URL=https://finance.yahoo.com/rss/topstories
# AI_MARKET_MARKETWATCH_RSS_URL=https://feeds.content.dowjones.io/public/rss/mw_topstories
# AI_MARKET_FEDERAL_RESERVE_RSS_URL=https://www.federalreserve.gov/feeds/press_all.xml

# Optional event enrichment source URL overrides.
# AI_MARKET_DAILYFX_CALENDAR_URL=https://www.dailyfx.com/economic-calendar
# AI_MARKET_FOREX_FACTORY_CALENDAR_URL=https://www.forexfactory.com/calendar
# AI_MARKET_INVESTING_CALENDAR_URL=https://www.investing.com/economic-calendar/
# AI_MARKET_FXSTREET_CALENDAR_URL=https://www.fxstreet.com/economic-calendar
# AI_MARKET_MARKETWATCH_CALENDAR_URL=https://www.marketwatch.com/economy-politics/calendar
# AI_MARKET_YAHOO_ECONOMIC_CALENDAR_URL=https://finance.yahoo.com/calendar/economic
# AI_MARKET_GENERIC_SEARCH_CALENDAR_URL=

# Optional multi-source provider controls.
AI_MARKET_ENABLE_MARKETBEAT_HOLIDAYS=true
AI_MARKET_ENABLE_CME_MARKET_SCHEDULE=true
AI_MARKET_CME_MARKET_SCHEDULE_TIMEOUT_SECONDS=10
AI_MARKET_CME_MARKET_SCHEDULE_TTL_HOURS=24
AI_MARKET_ENABLE_POLYMARKET=false
AI_MARKET_MARKETBEAT_TIMEOUT_SECONDS=10
AI_MARKET_MARKETBEAT_HOLIDAYS_TTL_HOURS=24
AI_MARKET_ENABLE_INVESTING_FED_RATE_MONITOR=true
AI_MARKET_INVESTING_FED_RATE_MONITOR_TIMEOUT_SECONDS=10
AI_MARKET_INVESTING_FED_RATE_MONITOR_TTL_MINUTES=30
AI_MARKET_INVESTING_FED_RATE_MONITOR_MAX_MEETINGS=8
# AI_MARKET_MARKETBEAT_HOLIDAYS_URL=https://www.marketbeat.com/stock-market-holidays/
# AI_MARKET_INVESTING_FED_RATE_MONITOR_URL=https://www.investing.com/central-banks/fed-rate-monitor
